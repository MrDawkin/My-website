---
const email       = 'Geraldinio_z_rivii@wp.pl';
const githubUrl   = 'https://github.com/MrDawkin';
const linkedinUrl = 'https://www.linkedin.com/in/dawid-kina/';
const cvUrl       = '';

const showCv       = false;
const showLinkedin = true;
---

<section id="contact" class="py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Section label -->
    <p class="font-mono text-xs text-blue-400/70 tracking-[0.2em] uppercase mb-2 reveal">
      07 / contact
    </p>

    <div class="max-w-xl reveal">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-100 tracking-tight mb-4">
        <span class="lang-pl">Skontaktuj się</span>
        <span class="lang-en">Get in touch</span>
      </h2>

      <p class="text-slate-400 leading-relaxed mb-10">
        <span class="lang-pl">
          Szukasz DevOps Engineera lub chcesz porozmawiać o automatyzacji i infrastrukturze?
          Napisz, odpiszę na każdą wiadomość.
        </span>
        <span class="lang-en">
          Looking for a DevOps Engineer or want to talk about automation and infrastructure?
          Reach out — I reply to every message.
        </span>
      </p>

      <!-- Linki kontaktowe -->
      <div class="flex flex-wrap items-center gap-3">

        <!-- Email — główny CTA -->
        <a
          href={`mailto:${email}`}
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-all duration-200 hover:-translate-y-px shadow-lg shadow-blue-500/20 w-full sm:w-auto justify-center sm:justify-start"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {email}
        </a>

        <!-- Kopiuj email -->
        <button
          id="copy-email-btn"
          data-email={email}
          aria-label="Kopiuj adres email"
          class="inline-flex items-center justify-center w-10 h-10 rounded-xl border border-brand-border bg-brand-surface hover:border-brand-hover text-slate-400 hover:text-slate-100 transition-all duration-200 flex-shrink-0"
        >
          <svg id="copy-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          <svg id="check-icon" class="w-4 h-4 text-green-400 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </button>

        <!-- GitHub -->
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-brand-border bg-brand-surface hover:border-brand-hover text-slate-400 hover:text-slate-100 text-sm font-medium transition-all duration-200"
          aria-label="GitHub"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          GitHub
        </a>

        <!-- LinkedIn -->
        {showLinkedin && (
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-brand-border bg-brand-surface hover:border-brand-hover text-slate-400 hover:text-slate-100 text-sm font-medium transition-all duration-200"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        )}

        <!-- CV download -->
        {showCv && (
          <a
            href={cvUrl}
            download
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-brand-border bg-brand-surface hover:border-brand-hover text-slate-400 hover:text-slate-100 text-sm font-medium transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span class="lang-pl">Pobierz CV</span>
            <span class="lang-en">Download CV</span>
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<script>
  const btn   = document.getElementById('copy-email-btn');
  const icon  = document.getElementById('copy-icon');
  const check = document.getElementById('check-icon');
  const label = document.getElementById('copy-label');

  const isEn  = () => document.documentElement.getAttribute('data-lang') === 'en';
  const t     = (pl: string, en: string) => isEn() ? en : pl;

  const syncLabel = () => {
    if (label) label.textContent = t('Kopiuj', 'Copy');
    btn?.setAttribute('aria-label', t('Kopiuj adres email', 'Copy email address'));
  };

  syncLabel();
  document.addEventListener('langchange', syncLabel);

  btn?.addEventListener('click', async () => {
    const email = (btn as HTMLButtonElement).dataset.email ?? '';
    try {
      await navigator.clipboard.writeText(email);
      icon?.classList.add('hidden');
      check?.classList.remove('hidden');
      if (label) label.textContent = t('Skopiowano!', 'Copied!');
      setTimeout(() => {
        icon?.classList.remove('hidden');
        check?.classList.add('hidden');
        syncLabel();
      }, 2000);
    } catch {
      // fallback: clipboard not available
    }
  });
</script>

<!-- Footer -->
<footer class="border-t border-brand-border py-8">
  <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="font-mono text-xs text-slate-600">
      &copy; {new Date().getFullYear()} Dawid Kina
    </p>
    <p class="font-mono text-xs text-slate-700">
      Built with Astro &amp; Tailwind CSS
    </p>
  </div>
</footer>
