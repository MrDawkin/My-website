---
import { projects } from '../data/projects';
---

<section id="projects" class="py-24 md:py-32 bg-brand-surface">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Section label -->
    <p class="font-mono text-xs text-blue-400/70 tracking-[0.2em] uppercase mb-2 reveal">
      05 / projects
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-slate-100 tracking-tight mb-14 reveal">
      <span class="lang-pl">Projekty</span>
      <span class="lang-en">Projects</span>
    </h2>

    <div class="grid md:grid-cols-2 gap-5 reveal-group">
      {projects.map((project) => project.placeholder ? (

        <!-- Placeholder slot -->
        <article class="reveal flex flex-col items-center justify-center rounded-2xl p-6 border border-dashed border-slate-800/70 bg-transparent min-h-[200px] text-center gap-3">
          <div class="w-10 h-10 rounded-xl border border-dashed border-slate-800 flex items-center justify-center">
            <svg class="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <div>
            <p class="font-mono text-xs text-slate-700 tracking-widest uppercase">
              <span class="lang-pl">Projekt w przygotowaniu</span>
              <span class="lang-en">Project in progress</span>
            </p>
            <p class="font-mono text-[10px] text-slate-800 mt-1">
              <span class="lang-pl">wkrótce</span>
              <span class="lang-en">coming soon</span>
            </p>
          </div>
        </article>

      ) : (

        <!-- Real project card -->
        <article
          class={`reveal flex flex-col rounded-2xl p-6 border transition-all duration-200 group
            ${project.featured
              ? 'bg-brand-bg border-blue-500/20 shadow-md shadow-blue-500/[0.06] hover:border-blue-500/35 hover:shadow-xl hover:shadow-blue-500/[0.10]'
              : 'bg-brand-bg border-brand-border hover:border-slate-700 hover:shadow-xl hover:shadow-black/30'
            }`}
        >
          <!-- Header: badge + tytuł + ikona folderu -->
          <div class="flex items-start justify-between gap-4 mb-4">
            <div class="flex-1 min-w-0">
              {(project.featured || project.wip) && (
                <div class="flex items-center gap-2 mb-2">
                  {project.featured && (
                    <span class="font-mono text-[10px] text-blue-400 border border-blue-500/30 rounded px-1.5 py-0.5 tracking-widest uppercase">
                      featured
                    </span>
                  )}
                  {project.wip && (
                    <span class="font-mono text-[10px] text-amber-400 border border-amber-500/30 rounded px-1.5 py-0.5 tracking-widest uppercase">
                      wip
                    </span>
                  )}
                </div>
              )}
              <h3 class="text-base font-semibold text-slate-100 tracking-tight group-hover:text-blue-400 transition-colors duration-200">
                {project.title}
              </h3>
            </div>

            <svg
              class="flex-shrink-0 w-8 h-8 text-slate-700 group-hover:text-blue-400/50 transition-colors duration-200"
              fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
            </svg>
          </div>

          <!-- Opis -->
          <p class="text-sm text-slate-400 leading-relaxed mb-5 flex-1">
            <span class="lang-pl">{project.description}</span>
            <span class="lang-en">{project.descriptionEn ?? project.description}</span>
          </p>

          <!-- Tech badges -->
          <div class="flex flex-wrap gap-2 mb-5">
            {project.tech.map((t) => (
              <span class="font-mono text-xs text-slate-400 bg-brand-surface border border-brand-border rounded-md px-2 py-0.5">
                {t}
              </span>
            ))}
          </div>

          <!-- Linki -->
          <div class="flex items-center gap-4 mt-auto">
            {project.githubUrl && project.githubUrl !== '[TODO: URL]' && (
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-200 transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                </svg>
                GitHub
              </a>
            )}
            {project.liveUrl && (
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-200 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                Live
              </a>
            )}
          </div>
        </article>

      ))}
    </div>
  </div>
</section>
