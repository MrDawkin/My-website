---
// Terminal — easter egg dla rekrutera technicznego.
// Komendy: help, whoami, about, experience, education, projects, stack, contact, clear
---

<section id="terminal" class="py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Section label -->
    <p class="font-mono text-xs text-blue-400/70 tracking-[0.2em] uppercase mb-2 reveal">
      06 / terminal
    </p>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 reveal">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-100">
          <span class="lang-pl">Terminal interaktywny</span>
          <span class="lang-en">Interactive Terminal</span>
        </h2>
        <p class="text-sm text-slate-500 mt-2 font-mono">
          <span class="lang-pl">Wpisz <span class="text-slate-400">'help'</span> aby zobaczyć komendy</span>
          <span class="lang-en">Type <span class="text-slate-400">'help'</span> to see available commands</span>
        </p>
      </div>
    </div>

    <!-- Mobile hint -->
    <p class="md:hidden font-mono text-xs text-slate-700 mb-4 reveal">
      <span class="lang-pl">↳ najlepiej działa na komputerze</span>
      <span class="lang-en">↳ best experienced on desktop</span>
    </p>

    <!-- Terminal window -->
    <div
      id="terminal-window"
      class="reveal bg-[#020617] border border-brand-border rounded-2xl overflow-hidden shadow-2xl shadow-black/40 transition-colors duration-200 focus-within:border-brand-hover"
    >
      <!-- Title bar -->
      <div class="flex items-center gap-2 px-4 py-3 border-b border-brand-border bg-[#020617]">
        <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
        <span class="ml-4 font-mono text-xs text-slate-500">bash — mr-dawkin@cloud</span>
      </div>

      <!-- Output area -->
      <div
        id="terminal-body"
        class="terminal-body font-mono text-sm px-5 py-4 min-h-[200px] max-h-[360px] overflow-y-auto"
      ></div>

      <!-- Input -->
      <div class="flex items-center gap-2 border-t border-brand-border px-5 py-3 bg-[#020617]">
        <span class="font-mono text-green-400 text-sm select-none flex-shrink-0">➜</span>
        <input
          type="text"
          id="terminal-input"
          placeholder="Wpisz komendę..."
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          class="flex-1 bg-transparent font-mono text-sm text-slate-200 placeholder:text-slate-700 caret-green-400 focus:outline-none"
        />
      </div>
    </div>
  </div>
</section>

<script>
// ─── DOM ───────────────────────────────────────────────────────────────────
const body  = document.getElementById('terminal-body')!;
const input = document.getElementById('terminal-input') as HTMLInputElement;

// ─── Lang helper ───────────────────────────────────────────────────────────
const isEn = () => document.documentElement.getAttribute('data-lang') === 'en';

// ─── Available commands ────────────────────────────────────────────────────
const COMMANDS = ['about', 'clear', 'contact', 'education', 'experience', 'help', 'projects', 'stack', 'whoami'];

// ─── Output helpers ────────────────────────────────────────────────────────
function line(text: string, cls = 'text-slate-400') {
  const el = document.createElement('div');
  el.className = `${cls} leading-relaxed mb-0.5 whitespace-pre`;
  el.textContent = text;
  body.appendChild(el);
  body.scrollTop = body.scrollHeight;
}

function rich(html: string) {
  const el = document.createElement('div');
  el.className = 'leading-relaxed mb-0.5 whitespace-pre';
  el.innerHTML = html;
  body.appendChild(el);
  body.scrollTop = body.scrollHeight;
}

function gap() {
  const el = document.createElement('div');
  el.className = 'mb-2';
  body.appendChild(el);
  body.scrollTop = body.scrollHeight;
}

const c = (cls: string, text: string) => `<span class="${cls}">${text}</span>`;

function promptLine(cmd: string) {
  const safe = cmd.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const el = document.createElement('div');
  el.className = 'flex gap-2 mb-1';
  el.innerHTML = `
    <span class="text-green-400 select-none flex-shrink-0">➜</span>
    <span class="text-cyan-400 select-none flex-shrink-0">mr-dawkin@cloud</span>
    <span class="text-amber-400 select-none flex-shrink-0">~</span>
    <span class="text-slate-200">$ ${safe}</span>
  `;
  body.appendChild(el);
  body.scrollTop = body.scrollHeight;
}

// ─── Command outputs ───────────────────────────────────────────────────────
function cmdHelp() {
  if (isEn()) {
    line('Available commands:', 'text-slate-500');
    line('', '');
    const cmds: [string, string][] = [
      ['help',       'show this message'],
      ['whoami',     'who am I'],
      ['about',      'short profile summary'],
      ['experience', 'work experience'],
      ['education',  'educational background'],
      ['projects',   'my projects'],
      ['stack',      'technologies I use'],
      ['contact',    'how to reach me'],
      ['clear',      'clear the terminal'],
    ];
    cmds.forEach(([cmd, desc]) => {
      rich(`  ${c('text-cyan-400', cmd.padEnd(12))}${c('text-slate-600', '— ')}${c('text-slate-500', desc)}`);
    });
  } else {
    line('Dostępne komendy:', 'text-slate-500');
    line('', '');
    const cmds: [string, string][] = [
      ['help',       'wyświetl tę wiadomość'],
      ['whoami',     'kim jestem'],
      ['about',      'krótki opis profilu'],
      ['experience', 'doświadczenie zawodowe'],
      ['education',  'wykształcenie'],
      ['projects',   'moje projekty'],
      ['stack',      'technologie'],
      ['contact',    'kontakt'],
      ['clear',      'wyczyść terminal'],
    ];
    cmds.forEach(([cmd, desc]) => {
      rich(`  ${c('text-cyan-400', cmd.padEnd(12))}${c('text-slate-600', '— ')}${c('text-slate-500', desc)}`);
    });
  }
}

function cmdWhoami() {
  rich(`${c('text-slate-100', 'Dawid Kina')} ${c('text-slate-600', '·')} ${c('text-blue-400', 'Junior DevOps Engineer')}`);
  rich(c('text-slate-500', 'Comarch · AI Enterprise Solutions, BU Technology & Products'));
  rich(`${c('text-slate-600', 'Wrocław, Poland')} ${c('text-slate-700', '·')} ${c('text-slate-500', 'github.com/MrDawkin')}`);
}

function cmdAbout() {
  if (isEn()) {
    line('Junior DevOps Engineer @ Comarch (AI Enterprise Solutions).', 'text-slate-400');
    line('Managing 200+ ERP environments: Linux, Windows Server, Docker.', 'text-slate-400');
    line('Automating tasks with Bash and Python scripts.', 'text-slate-400');
    line('Growing towards AWS and cloud infrastructure.', 'text-slate-400');
  } else {
    line('Junior DevOps Engineer @ Comarch (AI Enterprise Solutions).', 'text-slate-400');
    line('Administruję ponad 200 środowiskami ERP: Linux, Windows Server, Docker.', 'text-slate-400');
    line('Automatyzuję zadania skryptami Bash i Python.', 'text-slate-400');
    line('Rozwijam się w kierunku AWS i cloud.', 'text-slate-400');
  }
}

function cmdExperience() {
  if (isEn()) {
    rich(c('text-slate-600', '── Main experience ──────────────────────────────────'));
    line('', '');
    rich(`${c('text-slate-200', 'Comarch')} ${c('text-slate-600', '·')} ${c('text-blue-400', 'Junior DevOps Engineer')}  ${c('text-slate-500', 'September 2024 – present')}`);
    [
      'Administration of 200+ environments (Linux, Windows Server, Docker)',
      'Databases: PostgreSQL, MSSQL, MySQL',
      'Security: TLS/SSL, VPN, firewall, AES-256, BitLocker',
      'Bash/Python automation, documentation (Barman, Oxid WebShop)',
      '1st–3rd line support, collaboration with DE team',
    ].forEach(b => rich(`  ${c('text-blue-400', '▸')} ${c('text-slate-400', b)}`));
    line('', '');
    rich(`${c('text-slate-200', 'Comarch')} ${c('text-slate-600', '·')} ${c('text-blue-400', 'DevOps Intern')}             ${c('text-slate-500', 'July – September 2024')}`);
    [
      'Keycloak & Azure AD integration (SSO, IAM)',
      'Independent test environment for integration validation',
    ].forEach(b => rich(`  ${c('text-blue-400', '▸')} ${c('text-slate-400', b)}`));
    line('', '');
    rich(c('text-slate-600', '── Additional experience ────────────────────────────'));
    line('', '');
    [
      ['BonaSoft · Junior Front-end Developer',  'July – October 2022'        ],
      ['Webcraft · Junior Front-end Developer',   'March – April 2019'         ],
      ["McDonald's · Crew Member → Manager",      'September 2020 – July 2024' ],
    ].forEach(([role, period]) => {
      rich(`${c('text-slate-500', role!.padEnd(42))}${c('text-slate-600', period!)}`);
    });
  } else {
    rich(c('text-slate-600', '── Główne doświadczenie ─────────────────────────────────'));
    line('', '');
    rich(`${c('text-slate-200', 'Comarch')} ${c('text-slate-600', '·')} ${c('text-blue-400', 'Junior DevOps Engineer')}  ${c('text-slate-500', 'Wrzesień 2024 – obecnie')}`);
    [
      'Administracja 200+ środowiskami (Linux, Windows Server, Docker)',
      'Bazy danych: PostgreSQL, MSSQL, MySQL',
      'Bezpieczeństwo: TLS/SSL, VPN, firewall, AES-256, BitLocker',
      'Automatyzacja Bash/Python, dokumentacja (Barman, Oxid WebShop)',
      'Wsparcie 1.–3. linii, współpraca z zespołem DE',
    ].forEach(b => rich(`  ${c('text-blue-400', '▸')} ${c('text-slate-400', b)}`));
    line('', '');
    rich(`${c('text-slate-200', 'Comarch')} ${c('text-slate-600', '·')} ${c('text-blue-400', 'DevOps Intern')}             ${c('text-slate-500', 'Lipiec – Wrzesień 2024')}`);
    [
      'Integracja Keycloak i Azure AD z platformą (SSO, IAM)',
      'Samodzielne środowisko testowe do walidacji integracji',
    ].forEach(b => rich(`  ${c('text-blue-400', '▸')} ${c('text-slate-400', b)}`));
    line('', '');
    rich(c('text-slate-600', '── Dodatkowe doświadczenie ──────────────────────────────'));
    line('', '');
    [
      ['BonaSoft · Junior Front-end Developer',  'Lipiec – Październik 2022'    ],
      ['Webcraft · Junior Front-end Developer',   'Marzec – Kwiecień 2019'       ],
      ["McDonald's · Pracownik → Menedżer",       'Wrzesień 2020 – Lipiec 2024'  ],
    ].forEach(([role, period]) => {
      rich(`${c('text-slate-500', role!.padEnd(42))}${c('text-slate-600', period!)}`);
    });
  }
}

function cmdEducation() {
  if (isEn()) {
    rich(c('text-slate-200', 'Wrocław University of Science and Technology'));
    rich(`  ${c('text-blue-400', 'MSc')}   ${c('text-slate-300', 'Applied Computer Science')}          ${c('text-slate-500', 'February 2024 – July 2025')}`);
    rich(`        ${c('text-slate-600', 'Applications of Specialist IT Technologies')}`);
    line('', '');
    rich(`  ${c('text-blue-400', 'BEng')}  ${c('text-slate-300', 'Electronics')}                       ${c('text-slate-500', 'October 2020 – January 2024')}`);
    rich(`        ${c('text-slate-600', 'Applications of Computer Engineering in Technology')}`);
    line('', '');
    rich(c('text-slate-200', 'Elektroniczne Zakłady Naukowe · Wrocław'));
    rich(`  ${c('text-blue-400', 'IT Tech.')} ${c('text-slate-300', 'IT Technician')}                   ${c('text-slate-500', 'September 2016 – June 2020')}`);
  } else {
    rich(c('text-slate-200', 'Politechnika Wrocławska'));
    rich(`  ${c('text-blue-400', 'Mgr')}   ${c('text-slate-300', 'Informatyka stosowana')}          ${c('text-slate-500', 'Luty 2024 – Lipiec 2025')}`);
    rich(`        ${c('text-slate-600', 'Zastosowania specjalistycznych technologii informatycznych')}`);
    line('', '');
    rich(`  ${c('text-blue-400', 'inż.')}  ${c('text-slate-300', 'Elektronika')}                    ${c('text-slate-500', 'Październik 2020 – Styczeń 2024')}`);
    rich(`        ${c('text-slate-600', 'Zastosowania inżynierii komputerowej w technice')}`);
    line('', '');
    rich(c('text-slate-200', 'Elektroniczne Zakłady Naukowe · Wrocław'));
    rich(`  ${c('text-blue-400', 'T.inf.')} ${c('text-slate-300', 'Technik informatyk')}             ${c('text-slate-500', 'Wrzesień 2016 – Czerwiec 2020')}`);
  }
}

function cmdProjects() {
  rich(`${c('text-slate-200', 'Portfolio Website')}  ${c('text-blue-400', '[featured]')}`);
  rich(`  ${c('text-slate-500', 'tech')}   ${c('text-slate-300', 'Astro, Tailwind CSS, TypeScript, GitHub Actions')}`);
  rich(`  ${c('text-slate-500', 'repo')}   ${c('text-slate-400', 'github.com/MrDawkin/My-website')}`);
  rich(`  ${c('text-slate-500', 'live')}   ${c('text-slate-400', 'mrdawkin.github.io/My-website')}`);
  line('', '');
  rich(c('text-slate-700', isEn() ? '+ 2 projects in progress' : '+ 2 projekty w przygotowaniu'));
}

function cmdStack() {
  if (isEn()) {
    [
      ['Systems   ', 'Linux (daily), Windows Server, Windows'],
      ['Containers', 'Docker (daily), Docker Compose'],
      ['Scripts   ', 'Bash (daily), GitHub Actions'],
      ['VCS       ', 'Git (daily)'],
      ['Databases ', 'PostgreSQL, MSSQL, MySQL'],
      ['Security  ', 'TLS/SSL, VPN, Firewall, AES-256, BitLocker'],
      ['Learning  ', 'AWS, Python, Claude Code'],
    ].forEach(([cat, items]) => {
      rich(`  ${c('text-slate-500', cat!)}  ${c('text-slate-300', items!)}`);
    });
  } else {
    [
      ['Systemy   ', 'Linux (daily), Windows Server, Windows'],
      ['Kontenery ', 'Docker (daily), Docker Compose'],
      ['Skrypty   ', 'Bash (daily), GitHub Actions'],
      ['VCS       ', 'Git (daily)'],
      ['Bazy      ', 'PostgreSQL, MSSQL, MySQL'],
      ['Security  ', 'TLS/SSL, VPN, Firewall, AES-256, BitLocker'],
      ['Nauka     ', 'AWS, Python, Claude Code'],
    ].forEach(([cat, items]) => {
      rich(`  ${c('text-slate-500', cat!)}  ${c('text-slate-300', items!)}`);
    });
  }
}

function cmdContact() {
  [
    ['GitHub  ', 'https://github.com/MrDawkin'],
    ['LinkedIn', 'https://www.linkedin.com/in/dawid-kina/'],
    ['Email   ', 'Geraldinio_z_rivii@wp.pl'],
  ].forEach(([label, val]) => {
    rich(`  ${c('text-slate-500', label!)}  ${c('text-slate-300', val!)}`);
  });
}

// ─── State ─────────────────────────────────────────────────────────────────
let history: string[] = [];
let historyIdx = -1;

// ─── Command runner ────────────────────────────────────────────────────────
function run(raw: string) {
  const cmd = raw.trim();
  if (!cmd) return;

  history.unshift(cmd);
  historyIdx = -1;
  promptLine(cmd);

  switch (cmd.toLowerCase()) {
    case 'help':       cmdHelp();       break;
    case 'whoami':     cmdWhoami();     break;
    case 'about':      cmdAbout();      break;
    case 'experience': cmdExperience(); break;
    case 'education':  cmdEducation();  break;
    case 'projects':   cmdProjects();   break;
    case 'stack':      cmdStack();      break;
    case 'contact':    cmdContact();    break;
    case 'clear':
      body.innerHTML = '';
      return;
    default:
      line(isEn() ? `command not found: ${cmd}` : `komenda nieznana: ${cmd}`, 'text-red-400');
      if (isEn()) {
        rich(`type ${c('text-cyan-400', 'help')} ${c('text-slate-600', 'for available commands')}`);
      } else {
        rich(`wpisz ${c('text-cyan-400', 'help')} ${c('text-slate-600', 'aby zobaczyć komendy')}`);
      }
  }
  gap();
}

// ─── Tab completion ────────────────────────────────────────────────────────
function tabComplete() {
  const partial = input.value.toLowerCase();
  if (!partial) return;

  const matches = COMMANDS.filter(cmd => cmd.startsWith(partial));

  if (matches.length === 1) {
    input.value = matches[0]!;
  } else if (matches.length > 1) {
    promptLine(input.value);
    rich(matches.map(m => c('text-cyan-400', m)).join(c('text-slate-700', '   ')));
    gap();
  }
}

// ─── Events ────────────────────────────────────────────────────────────────
input.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    run(input.value);
    input.value = '';
    return;
  }
  if (e.key === 'Tab') {
    e.preventDefault();
    tabComplete();
    return;
  }
  if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (historyIdx < history.length - 1) {
      historyIdx++;
      input.value = history[historyIdx]!;
    }
    return;
  }
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (historyIdx > 0) {
      historyIdx--;
      input.value = history[historyIdx]!;
    } else {
      historyIdx = -1;
      input.value = '';
    }
  }
});

document.getElementById('terminal-window')?.addEventListener('click', () => input.focus());

// ─── Lang change — update placeholder ─────────────────────────────────────
document.addEventListener('langchange', (e: Event) => {
  const { lang } = (e as CustomEvent<{ lang: string }>).detail;
  input.placeholder = lang === 'en' ? 'Type a command...' : 'Wpisz komendę...';
});

// ─── Welcome ───────────────────────────────────────────────────────────────
input.placeholder = isEn() ? 'Type a command...' : 'Wpisz komendę...';

if (isEn()) {
  line('Welcome — mr-dawkin@cloud ~', 'text-slate-500');
  rich(`Type ${c('text-cyan-400', 'help')} ${c('text-slate-600', 'to see available commands.')}`);
} else {
  line('Witaj — mr-dawkin@cloud ~', 'text-slate-500');
  rich(`Wpisz ${c('text-cyan-400', 'help')} ${c('text-slate-600', 'aby zobaczyć komendy.')}`);
}
gap();
</script>
