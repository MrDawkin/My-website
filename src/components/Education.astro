---
import { education } from '../data/education';
---

<section id="education" class="py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Section label -->
    <p class="font-mono text-xs text-blue-400/70 tracking-[0.2em] uppercase mb-2 reveal">
      04 / education
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-slate-100 tracking-tight mb-14 reveal">
      <span class="lang-pl">Wykształcenie</span>
      <span class="lang-en">Education</span>
    </h2>

    <div class="space-y-5">
      {education.map((entry) => (
        <div class="reveal">
          <div class="bg-brand-surface border border-brand-border rounded-2xl p-6 md:p-8 hover:border-slate-700 transition-all duration-200">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">

              <div>
                <span class="inline-block font-mono text-[10px] text-blue-400 border border-blue-500/30 rounded px-1.5 py-0.5 tracking-widest uppercase mb-2">
                  <span class="lang-pl">{entry.degree}</span>
                  <span class="lang-en">{entry.degreeEn ?? entry.degree}</span>
                </span>
                <h3 class="text-base font-semibold text-slate-100 tracking-tight">
                  <span class="lang-pl">{entry.field}</span>
                  <span class="lang-en">{entry.fieldEn ?? entry.field}</span>
                </h3>
                <p class="text-sm text-slate-400 mt-0.5 font-mono">
                  <span class="lang-pl">{entry.school}</span>
                  <span class="lang-en">{entry.schoolEn ?? entry.school}</span>
                </p>
                {entry.specialization && (
                  <p class="text-xs text-slate-500 mt-1.5">
                    <span class="lang-pl">{entry.specialization}</span>
                    <span class="lang-en">{entry.specializationEn ?? entry.specialization}</span>
                  </p>
                )}
              </div>

              <span class="flex-shrink-0 self-start font-mono text-xs text-slate-400 bg-brand-bg border border-brand-border rounded-lg px-3 py-1.5">
                {entry.period.start}{entry.period.end ? ` — ${entry.period.end}` : <span><span class="lang-pl"> — obecnie</span><span class="lang-en"> — present</span></span>}
              </span>

            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
