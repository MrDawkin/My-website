---
import { Image } from 'astro:assets';
import profileImg from '../assets/images/profile.jpg';

const firstName   = 'Dawid';
const lastName    = 'Kina';
const title       = 'Junior DevOps Engineer';
const keywords    = ['Linux', 'Windows Server', 'Docker', 'PostgreSQL', 'MSSQL'];
const status      = 'Otwarty na oferty';
const githubUrl   = 'https://github.com/MrDawkin';
const linkedinUrl = 'https://www.linkedin.com/in/dawid-kina/';

const hasLastName = lastName && lastName.trim() !== '';
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-brand-bg">

  <!-- Dot grid — subtelna tekstura tła -->
  <div class="absolute inset-0 dot-grid pointer-events-none" aria-hidden="true"></div>

  <!--
    Gradient blobs — ambient light effect.
    Dają głębię bez performance cost-u.
    Lewy blob: nad tekstem. Prawy: balansuje kompozycję.
  -->
  <div
    class="absolute top-[5%] left-[-15%] w-[700px] h-[550px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(59,130,246,0.055) 0%, transparent 70%); filter: blur(1px);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-[0%] right-[-8%] w-[500px] h-[400px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(99,102,241,0.04) 0%, transparent 70%); filter: blur(1px);"
    aria-hidden="true"
  ></div>

  <!-- Gradient fade — płynne przejście do kolejnej sekcji -->
  <div
    class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-brand-bg to-transparent pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-24 pb-20 md:py-32 w-full">
    <div class="grid md:grid-cols-5 gap-10 md:gap-16 items-center">

      <!-- ── Lewa kolumna: tekst ──────────────────────────────────── -->
      <div class="md:col-span-3">

        <!-- Label — krótki, mono, niezbyt dominujący -->
        <p
          class="font-mono text-blue-400/60 text-xs tracking-[0.2em] uppercase mb-4 opacity-0 animate-fade-in"
          style="animation-delay: 0.05s; animation-fill-mode: forwards"
        >
          &gt;_ junior devops engineer
        </p>

        <!-- Imię — główny nagłówek z gradient text -->
        <h1
          class="gradient-text text-[clamp(52px,7.5vw,88px)] font-bold leading-[0.95] tracking-tight mb-3 opacity-0 animate-fade-in"
          style="animation-delay: 0.15s; animation-fill-mode: forwards"
        >
          {firstName}{hasLastName && <span class="text-slate-400"> {lastName}</span>}
        </h1>

        <!-- Subtitle — tytuł zawodowy jako oddzielna linia -->
        <p
          class="text-slate-400 text-xl md:text-2xl font-medium tracking-tight mb-8 opacity-0 animate-fade-in"
          style="animation-delay: 0.22s; animation-fill-mode: forwards"
        >
          {title}
        </p>

        <!-- Słowa kluczowe — mono, bardzo stonowane -->
        <p
          class="font-mono text-slate-600 text-sm mb-6 opacity-0 animate-fade-in"
          style="animation-delay: 0.30s; animation-fill-mode: forwards"
        >
          {keywords.join(' · ')}
        </p>

        <!-- Status badge -->
        {status && (
          <div
            class="inline-flex items-center gap-2 mb-10 opacity-0 animate-fade-in"
            style="animation-delay: 0.38s; animation-fill-mode: forwards"
          >
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-60"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-green-400"></span>
            </span>
            <span class="text-sm text-slate-500 font-mono">
              <span class="lang-pl">{status}</span>
              <span class="lang-en">Open to work</span>
            </span>
          </div>
        )}

        <!-- CTA buttons -->
        <div
          class="flex flex-wrap items-center gap-3 opacity-0 animate-fade-in"
          style="animation-delay: 0.46s; animation-fill-mode: forwards"
        >
          <!-- GitHub -->
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-brand-border bg-brand-surface hover:border-slate-600 hover:bg-white/[0.04] text-slate-200 text-sm font-medium transition-all duration-200 hover:-translate-y-px"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
            GitHub
            <svg class="w-3.5 h-3.5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-all duration-200 hover:-translate-y-px shadow-lg shadow-blue-500/20 hover:shadow-blue-500/30"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
            <svg class="w-3.5 h-3.5 text-blue-200/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- ── Prawa kolumna: zdjęcie ───────────────────────────────── -->
      <div
        class="md:col-span-2 flex justify-center md:justify-end opacity-0 animate-fade-in"
        style="animation-delay: 0.20s; animation-fill-mode: forwards"
      >
        <div class="relative">
          <!--
            Directional ambient glow — tylko z jednej strony (lewy górny).
            Nie okalający (stare rozwiązanie), ale ukierunkowany.
            Efekt: zdjęcie "świeci" w stronę tekstu.
          -->
          <div
            class="absolute -top-10 -left-10 w-60 h-60 rounded-full pointer-events-none"
            style="background: radial-gradient(ellipse at 30% 30%, rgba(59,130,246,0.12) 0%, transparent 70%);"
            aria-hidden="true"
          ></div>

          <!--
            Gradient border wrapper.
            p-px = 1px padding = 1px gradient border widoczny jako obramowanie.
            background gradient: blue → indigo → ciemny → efekt świecącego obramowania.
          -->
          <div
            class="relative p-px rounded-2xl"
            style="background: linear-gradient(135deg, rgba(59,130,246,0.5) 0%, rgba(99,102,241,0.25) 45%, rgba(30,41,59,0.2) 100%);"
          >
            <Image
              src={profileImg}
              alt="Dawid Kina — Junior DevOps Engineer"
              width={320}
              height={320}
              class="block w-56 h-56 md:w-72 md:h-72 object-cover rounded-[15px]"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator — widoczny (slate-500, nie slate-700) -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 opacity-0 animate-fade-in"
      style="animation-delay: 0.75s; animation-fill-mode: forwards"
      aria-hidden="true"
    >
      <span class="text-[10px] font-mono text-slate-500 tracking-[0.2em] uppercase">scroll</span>
      <svg class="w-4 h-4 text-slate-500 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</section>
